{
  "kind": "collectionType",
  "collectionName": "articulos",
  "info": {
    "singularName": "articulo",
    "pluralName": "articulos",
    "displayName": "Artículo",
    "description": "Artículos, noticias, notas del presidente y debates"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "titulo": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "titulo",
      "required": true
    },
    "extracto": {
      "type": "text"
    },
    "contenido": {
      "type": "richtext"
    },
    "imagen_portada": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "fecha_publicacion": {
      "type": "date"
    },
    "destacado": {
      "type": "boolean",
      "default": false
    },
    "autor": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::autor.autor"
    },
    "categoria": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::categoria.categoria"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag"
    },
    "articulos_relacionados": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::articulo.articulo"
    }
  }
}
